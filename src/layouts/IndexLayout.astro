---
import Gtm from '../components/shared/Gtm.astro';
import GtmBody from '../components/shared/GtmBody.astro';
import Maps from '../components/shared/Maps.astro';

interface Props {
  title: string;
  ogTitle: string;
  description: string;
  ogDescription: string;
  keywords: string;
}

const { title, ogTitle, description, ogDescription, keywords } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <Gtm />
    <Maps />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index" />
    <title>{title}</title>
    <link rel="canonical" href={`https://labstudiomedia.com${Astro.url.pathname}`} />
    <meta
      name="google-site-verification"
      content="O5K-700LvgkrdOo5Ir4cyfOGDaastTK5-TNAC-4utPo"
    />
    <meta property="og:title" content={ogTitle} />
    <meta name="description" content={description} />
    <meta property="og:description" content={ogDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="LabStudioMedia" />
    <meta name="og:author" content="LabStudioMedia" />
    <meta name="og:site_name" content="LABSTUDIO | Marketing Digital" />
    <meta property="og:type" content="website" />
    <meta
      property="og:image"
      itemprop="image primaryImageOfPage"
      content="https://labstudiomedia.com/pageView.webp"
    />
    <meta property="og:url" content="https://labstudiomedia.com/" />
    <link rel="shortcut icon" type="icon" href="/favicon/favicon.ico" />
    <link rel="icon" href="/favicon/32x32.png" sizes="32x32">
    <link rel="icon" href="/favicon/48x48.png" sizes="48x48">
    <link rel="icon" href="/favicon/96x96.png" sizes="96x96">
    <link rel="icon" href="/favicon/144x144.png" sizes="144x144">
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://labstudiomedia.com/#organization",
      "name": "LabStudio Media",
      "url": "https://labstudiomedia.com",
      "logo": "https://labstudiomedia.com/favicon/144x144.png",
      "image": "https://labstudiomedia.com/pageView.webp",
      "description": "Agencia de marketing digital en Los Mochis, Sinaloa. Servicios de marketing digital, producción de video, fotografía, desarrollo web y tarjetas NFC para negocios en todo México.",
      "telephone": "+526681057964",
      "email": "contacto@labstudiomedia.com",
      "foundingLocation": {
        "@type": "Place",
        "name": "Los Mochis, Sinaloa, México"
      },
      "areaServed": {
        "@type": "Country",
        "name": "México"
      },
      "sameAs": [
        "https://www.instagram.com/labstudiomedia/",
        "https://www.facebook.com/labstudiomedia/",
        "https://www.tiktok.com/@labstudiomedia",
        "https://www.linkedin.com/company/labstudiomedia/",
        "https://www.youtube.com/@labstudiomedia"
      ],
      "inLanguage": "es-MX"
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://labstudiomedia.com/#website",
      "url": "https://labstudiomedia.com",
      "name": "LABSTUDIO | Marketing Digital",
      "description": "Agencia de marketing digital, desarrollo web y tarjetas NFC en Los Mochis, Sinaloa.",
      "inLanguage": "es-MX",
      "publisher": {
        "@id": "https://labstudiomedia.com/#organization"
      }
    }
    </script>
    <link rel="stylesheet" href="/styles/theme.bundle.css" />
    <link rel="stylesheet" href="/styles/libs.bundle.css" />
    <link rel="stylesheet" href="/styles/shared.css" />
  </head>
  <body>
    <GtmBody />
    <slot />
  </body>
  <script is:inline src="/js/theme.bundle.js"></script>
  <script is:inline src="/js/vendor.bundle.js"></script>
</html>
