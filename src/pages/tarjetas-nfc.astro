---
import SubPageLayout from "../layouts/SubPageLayout.astro";
import Footer from "../components/shared/Footer.astro";
import Nav from "../components/shared/Nav.astro";
import WhatsApp from "../components/shared/WhatsApp.astro";
import CustomBtn from "../components/shared/CustomBtn.astro";
---

<SubPageLayout
  title="LABSTUDIO | Tarjetas NFC Personalizadas para Empresas | Los Mochis"
  ogTitle="LABSTUDIO | Tarjetas NFC Personalizadas para Empresas y Freelancers"
  description="Tarjetas de presentación NFC de PVC rígido personalizadas para empresas y freelancers. Transfiere tu contacto completo con un solo toque. Diseño a tu imagen corporativa."
  ogDescription="Moderniza la presentación de tu equipo con tarjetas NFC. Diseño corporativo, control centralizado y tecnología de vanguardia. LabStudio Media, Los Mochis."
  keywords="tarjetas NFC, tarjetas de presentación NFC, tarjetas inteligentes empresariales, NFC México, tarjetas contactless, vCard NFC, tarjetas digitales, presentación empresarial, NFC Los Mochis, Sinaloa, tarjetas PVC NFC, tarjetas corporativas, networking digital"
>
  <Nav />

  <!-- ===== HERO ===== -->
  <section
    class="hero-nfc d-flex justify-content-center align-items-center position-relative"
  >
    <div class="container position-relative" style="z-index: 2;">
      <div class="row align-items-center justify-content-center gy-6">

        <!-- Text -->
        <div class="col-12 col-lg-6 text-center text-lg-start" data-aos="fade-up">
          <span class="nfc-eyebrow purple-eyebrow-text fw-semibold text-uppercase">
            Tecnología NFC · Presentación Profesional
          </span>
          <h1 class="hero-nfc-title fw-bold mt-3 mb-4">
            Conexiones Corporativas de
            <span class="text-labs-gradient">Alto Impacto</span>
          </h1>
          <p class="hero-nfc-sub text-body-secondary mb-5">
            Estandariza la presentación de tu equipo, proyecta innovación y
            facilita el cierre de negocios con Tarjetas de Presentación NFC de
            alta durabilidad.
          </p>
          <div
            class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start"
          >
            <CustomBtn
              isPrimary={true}
              extraClasses="hero-btn-font-fix px-4 py-3"
              href="https://wa.me/526681057964?text=Hola%20LabStudio%2C%20me%20interesan%20las%20Tarjetas%20NFC!"
              blank={true}
            >
              Quiero mis Tarjetas NFC
            </CustomBtn>
            <CustomBtn
              isPrimary={false}
              extraClasses="hero-btn-font-fix px-4 py-3"
              href="#aplicaciones"
            >
              Ver Aplicaciones
            </CustomBtn>
          </div>

          <!-- Quick stats -->
          <div
            class="hero-stats d-flex gap-4 mt-6 justify-content-center justify-content-lg-start flex-wrap"
          >
            <div class="stat-item">
              <span class="stat-number fw-bold">1</span>
              <span class="stat-label text-body-secondary">Solo un toque</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-number fw-bold">∞</span>
              <span class="stat-label text-body-secondary">Actualizaciones</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-number fw-bold">0</span>
              <span class="stat-label text-body-secondary">Papel desperdiciado</span>
            </div>
          </div>
        </div>

        <!-- Card visual -->
        <div
          class="col-12 col-lg-5 d-flex justify-content-center"
          data-aos="fade-left"
          data-aos-delay="200"
        >
          <div class="nfc-card-showcase">
            <div class="card-stack">
              <div class="biz-card biz-card--back"></div>
              <div class="biz-card biz-card--mid"></div>
              <div class="biz-card biz-card--front">
                <!-- Logo area -->
                <div class="card-logo">
                  <div class="card-logo-dot"></div>
                  <span class="card-logo-text">EMPRESA</span>
                </div>

                <!-- NFC symbol -->
                <div class="nfc-symbol-container">
                  <svg
                    class="nfc-icon"
                    viewBox="0 0 60 60"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M22 32 Q22 18 32 18 Q42 18 42 32"
                      stroke="rgba(255,255,255,0.95)"
                      stroke-width="2.8"
                      stroke-linecap="round"
                      fill="none"></path>
                    <path
                      d="M15 32 Q15 10 32 10 Q49 10 49 32"
                      stroke="rgba(255,255,255,0.55)"
                      stroke-width="2.8"
                      stroke-linecap="round"
                      fill="none"></path>
                    <path
                      d="M8 32 Q8 2 32 2 Q56 2 56 32"
                      stroke="rgba(255,255,255,0.25)"
                      stroke-width="2.8"
                      stroke-linecap="round"
                      fill="none"></path>
                    <circle cx="32" cy="39" r="3.5" fill="rgba(255,255,255,0.95)"
                    ></circle>
                  </svg>
                </div>

                <!-- Name info -->
                <div class="card-info">
                  <div class="card-name">Carlos Mendoza</div>
                  <div class="card-title-text">Director Comercial</div>
                </div>

                <!-- Tap ripple -->
                <div class="tap-ripple"></div>
                <div class="tap-ripple tap-ripple--2"></div>
              </div>
            </div>

            <!-- Phone mockup -->
            <div class="phone-mockup" data-aos="fade-up" data-aos-delay="500">
              <div class="phone-screen">
                <div class="contact-received">
                  <div class="contact-avatar"></div>
                  <div class="contact-details">
                    <div class="contact-name-mock">Carlos Mendoza</div>
                    <div class="contact-added-text">Contacto agregado ✓</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Background orbs -->
    <div class="position-absolute hsg-1" data-aos="fade-in" data-aos-duration="600">
      <div class="radial-purple-nfc" style="width: 28rem; height: 28rem;"></div>
    </div>
    <div class="position-absolute hsg-2" data-aos="fade-in" data-aos-duration="600">
      <div class="radial-purple-nfc" style="width: 24rem; height: 24rem;"></div>
    </div>
  </section>
  <!-- /Hero -->

  <!-- ===== EL NUEVO ESTÁNDAR ===== -->
  <section class="nuevo-estandar py-12">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 text-center" data-aos="fade-up">
          <h6 class="text-uppercase purple-eyebrow-text fw-bold mb-3">
            El Nuevo Estándar
          </h6>
          <h2 class="display-5 fw-bold mb-4">En presentación de negocios</h2>
          <p class="text-body-secondary fs-5 mb-0">
            En el mundo corporativo, la primera impresión define el éxito.
            Transiciona a credenciales de
            <strong>PVC rígido con tecnología NFC integrada</strong>: una
            inversión inteligente que reduce costos recurrentes de imprenta,
            protege el medio ambiente y garantiza que la información de tu
            empresa llegue directamente a la agenda de tus prospectos.
          </p>
        </div>
      </div>

      <!-- 3 key benefits -->
      <div class="row g-4 mt-6 justify-content-center">
        <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="50">
          <div class="benefit-pill text-center p-5 h-100">
            <div class="benefit-icon-wrap mx-auto mb-4">
              <svg
                width="26"
                height="26"
                fill="#fff"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M12,0C5.383,0,0,5.383,0,12c.603,15.898,23.4,15.894,24,0,0-6.617-5.383-12-12-12Zm1,17v1c-.005,1.308-1.995,1.307-2,0v-1h-.268c-1.067,0-2.063-.574-2.598-1.499-.277-.479-.113-1.09,.364-1.366,.479-.279,1.091-.113,1.366,.364,.179,.31,.511,.501,.867,.501h2.268c.997,.065,1.443-1.55,.356-1.76l-3.041-.507c-3.502-.649-2.748-5.753,.685-5.733v-1c.006-1.308,1.995-1.307,2,0v1h.268c1.067,0,2.063,.575,2.598,1.5,.277,.478,.113,1.089-.364,1.366-.48,.277-1.091,.113-1.366-.365-.179-.309-.511-.5-.867-.5h-2.268c-.997-.065-1.442,1.55-.356,1.76l3.041,.507c3.502,.649,2.748,5.753-.685,5.733Z"
                ></path>
              </svg>
            </div>
            <h3 class="h5 fw-bold mb-3">Reduce Costos de Imprenta</h3>
            <p class="text-body-secondary mb-0">
              Una sola tarjeta reemplaza cientos de impresiones. Actualiza los
              datos de cualquier colaborador de forma remota, sin costo adicional.
            </p>
          </div>
        </div>
        <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="100">
          <div class="benefit-pill text-center p-5 h-100">
            <div class="benefit-icon-wrap mx-auto mb-4">
              <svg
                width="26"
                height="26"
                fill="#fff"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M22,0c0,0-8.759.017-13.384,4.646C5.761,7.491,5.02,11.088,5.879,14.253l-5.586,5.454,1.414,1.449,5.527-5.396c.879.297,1.788.444,2.695.444,2.898,0,5.784-1.244,7.842-3.607C22.15,7.381,22,0,22,0Zm-5.743,11.571c-1.565,1.826-3.813,2.755-6.073,2.602l7.989-7.802-1.414-1.449-8.046,7.858c-.415-2.253.339-4.634,2.055-6.346C14.026,2.682,19.268,2.059,20.896,2c-.064,1.653-.69,6.933-4.639,11.571Z"
                ></path>
              </svg>
            </div>
            <h3 class="h5 fw-bold mb-3">Protege el Medio Ambiente</h3>
            <p class="text-body-secondary mb-0">
              Elimina el uso de papel para siempre. Una tarjeta NFC tiene una
              vida útil de años sin necesidad de reimprimirse.
            </p>
          </div>
        </div>
        <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="150">
          <div class="benefit-pill text-center p-5 h-100">
            <div class="benefit-icon-wrap mx-auto mb-4">
              <svg
                width="26"
                height="26"
                fill="#fff"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M13,0L1,14h10l-1,10,13-14h-10L13,0z"
                ></path>
              </svg>
            </div>
            <h3 class="h5 fw-bold mb-3">Contacto Instantáneo</h3>
            <p class="text-body-secondary mb-0">
              Un solo toque transmite toda tu información directamente a la
              agenda del cliente. Sin fricción, sin errores de dedo.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Nuevo estándar -->

  <!-- ===== APLICACIONES ESTRATÉGICAS ===== -->
  <section id="aplicaciones" class="aplicaciones-section py-12">
    <div class="container">
      <div class="row justify-content-center mb-8">
        <div class="col-12 col-md-10 col-lg-8 text-center" data-aos="fade-up">
          <h6 class="text-uppercase purple-eyebrow-text fw-bold mb-3">
            Casos de Uso
          </h6>
          <h2 class="display-5 fw-bold">
            Aplicaciones Estratégicas para tu Industria
          </h2>
        </div>
      </div>

      <div class="use-cases-grid">
        <div class="use-case-item" data-aos="fade-up" data-aos-delay="0">
          <div class="use-case-icon">
            <span>📇</span>
          </div>
          <div class="use-case-content">
            <h3 class="h5 fw-bold mb-2">V-Card Dinámica Integral</h3>
            <p class="text-body-secondary mb-0">
              La tarjeta transfiere el perfil completo del ejecutivo (nombre,
              puesto, extensiones, correos, foto y sitio web) directamente a los
              contactos del cliente. Sin errores de dedo ni tarjetas perdidas.
            </p>
          </div>
        </div>

        <div class="use-case-item" data-aos="fade-up" data-aos-delay="50">
          <div class="use-case-icon">
            <span>📦</span>
          </div>
          <div class="use-case-content">
            <h3 class="h5 fw-bold mb-2">Catálogos B2B al Instante</h3>
            <p class="text-body-secondary mb-0">
              Si tu fuerza de ventas distribuye insumos para restaurantes,
              productos de limpieza industrial o agroquímicos, un solo toque
              puede descargar la ficha técnica en PDF o abrir la tienda B2B en
              el dispositivo del comprador.
            </p>
          </div>
        </div>

        <div class="use-case-item" data-aos="fade-up" data-aos-delay="100">
          <div class="use-case-icon">
            <span>🎓</span>
          </div>
          <div class="use-case-content">
            <h3 class="h5 fw-bold mb-2">Reclutamiento y Difusión Institucional</h3>
            <p class="text-body-secondary mb-0">
              Excelente herramienta para universidades y escuelas. Los asesores
              de admisiones pueden transferir folletos de carreras, planes de
              estudio o formularios de inscripción directamente a los aspirantes
              durante ferias educativas.
            </p>
          </div>
        </div>

        <div class="use-case-item" data-aos="fade-up" data-aos-delay="150">
          <div class="use-case-icon">
            <span>🔄</span>
          </div>
          <div class="use-case-content">
            <h3 class="h5 fw-bold mb-2">Control Centralizado (Bajas y Cambios)</h3>
            <p class="text-body-secondary mb-0">
              La tarjeta física pertenece a la empresa. Si un empleado cambia de
              puesto o de número, o si hay rotación de personal, la información
              digital se actualiza de manera remota sin necesidad de emitir un
              plástico nuevo.
            </p>
          </div>
        </div>

        <div class="use-case-item" data-aos="fade-up" data-aos-delay="200">
          <div class="use-case-icon">
            <span>📊</span>
          </div>
          <div class="use-case-content">
            <h3 class="h5 fw-bold mb-2">Captación de Leads en Campo</h3>
            <p class="text-body-secondary mb-0">
              Enlaza la tarjeta a una landing page del vendedor donde el
              prospecto pueda dejar su correo o agendar una demostración en el
              momento justo.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Aplicaciones -->

  <!-- ===== DISEÑO Y CONFIGURACIÓN ===== -->
  <section class="diseno-section py-12 position-relative overflow-hidden">
    <div class="diseno-bg-gradient"></div>
    <div class="container position-relative" style="z-index: 1;">
      <div class="row align-items-center gy-8">
        <div class="col-12 col-lg-6" data-aos="fade-right">
          <h6 class="text-uppercase purple-eyebrow-text fw-bold mb-3">
            Personalización Total
          </h6>
          <h2 class="display-5 fw-bold mb-4">
            Diseño y Configuración a Nivel Empresarial
          </h2>
          <p class="text-body-secondary fs-5 mb-5">
            Entendemos la importancia del branding. Ofrecemos personalización
            total del PVC rígido para alinear el diseño a la identidad visual de
            tu marca, logrando un acabado profesional, minimalista y sobrio. Nos
            encargamos de la codificación y el enrutamiento de datos para cada
            miembro de tu equipo.
          </p>
          <ul class="design-features-list list-unstyled">
            <li class="design-feature-item">
              <div class="dfi-check">✓</div>
              <span>Diseño 100% alineado a tu identidad corporativa</span>
            </li>
            <li class="design-feature-item">
              <div class="dfi-check">✓</div>
              <span
                >Codificación y enrutamiento de datos para cada miembro del
                equipo</span
              >
            </li>
            <li class="design-feature-item">
              <div class="dfi-check">✓</div>
              <span>PVC rígido de alta durabilidad</span>
            </li>
            <li class="design-feature-item">
              <div class="dfi-check">✓</div>
              <span>Actualización remota de información en cualquier momento</span>
            </li>
            <li class="design-feature-item">
              <div class="dfi-check">✓</div>
              <span
                >Compatible con todos los smartphones modernos (iOS y Android)</span
              >
            </li>
          </ul>
        </div>

        <!-- Card variants showcase -->
        <div
          class="col-12 col-lg-6 d-flex justify-content-center"
          data-aos="fade-left"
          data-aos-delay="100"
        >
          <div class="brand-customization-demo">
            <p class="demo-label text-body-secondary mb-4 text-center fw-medium">
              Tu tarjeta, tu identidad
            </p>
            <div class="card-variants">
              <div class="variant-card variant-dark">
                <div class="variant-nfc-icon">
                  <svg viewBox="0 0 40 40" fill="none" width="28" height="28">
                    <path
                      d="M13 22 Q13 13 20 13 Q27 13 27 22"
                      stroke="rgba(255,255,255,0.85)"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      fill="none"></path>
                    <path
                      d="M9 22 Q9 8 20 8 Q31 8 31 22"
                      stroke="rgba(255,255,255,0.45)"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      fill="none"></path>
                    <circle cx="20" cy="27" r="2.5" fill="rgba(255,255,255,0.85)"
                    ></circle>
                  </svg>
                </div>
                <span class="variant-name">Ejecutivo</span>
              </div>

              <div class="variant-card variant-purple">
                <div class="variant-nfc-icon">
                  <svg viewBox="0 0 40 40" fill="none" width="28" height="28">
                    <path
                      d="M13 22 Q13 13 20 13 Q27 13 27 22"
                      stroke="rgba(255,255,255,0.85)"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      fill="none"></path>
                    <path
                      d="M9 22 Q9 8 20 8 Q31 8 31 22"
                      stroke="rgba(255,255,255,0.45)"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      fill="none"></path>
                    <circle cx="20" cy="27" r="2.5" fill="rgba(255,255,255,0.85)"
                    ></circle>
                  </svg>
                </div>
                <span class="variant-name">Corporativo</span>
              </div>

              <div class="variant-card variant-light">
                <div class="variant-nfc-icon">
                  <svg viewBox="0 0 40 40" fill="none" width="28" height="28">
                    <path
                      d="M13 22 Q13 13 20 13 Q27 13 27 22"
                      stroke="rgba(80,40,160,0.8)"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      fill="none"></path>
                    <path
                      d="M9 22 Q9 8 20 8 Q31 8 31 22"
                      stroke="rgba(80,40,160,0.4)"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      fill="none"></path>
                    <circle cx="20" cy="27" r="2.5" fill="rgba(80,40,160,0.8)"
                    ></circle>
                  </svg>
                </div>
                <span class="variant-name variant-name--dark">Minimalista</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Diseño -->

  <!-- ===== PARA QUIÉN ES ===== -->
  <section class="target-section py-12">
    <div class="container">
      <div class="row justify-content-center mb-8">
        <div
          class="col-12 col-md-10 col-lg-7 text-center"
          data-aos="fade-up"
        >
          <h6 class="text-uppercase purple-eyebrow-text fw-bold mb-3">
            ¿Para quién es?
          </h6>
          <h2 class="display-5 fw-bold">
            Ideal para Empresas y Freelancers
          </h2>
        </div>
      </div>

      <div class="row g-4 justify-content-center">
        <div class="col-12 col-md-6 col-lg-5" data-aos="fade-up" data-aos-delay="50">
          <div class="target-card h-100 p-5">
            <div class="target-icon mb-4">
              <svg
                width="38"
                height="38"
                fill="#633fb9"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M19,17a5.994,5.994,0,0,1-3-.806A5.994,5.994,0,0,1,13,17H11a5.938,5.938,0,0,1-3-.818A5.936,5.936,0,0,1,5,17H4a5.949,5.949,0,0,1-3-.813V21a3,3,0,0,0,3,3H20a3,3,0,0,0,3-3V16.188A5.958,5.958,0,0,1,20,17Z"
                ></path>
                <path
                  d="M17,0V6H15V0H9V6H7V0H2.2L.024,9.783,0,11a4,4,0,0,0,4,4H5a3.975,3.975,0,0,0,3-1.382A3.975,3.975,0,0,0,11,15h2a3.99,3.99,0,0,0,3-1.357A3.99,3.99,0,0,0,19,15h1a4,4,0,0,0,4-4V10L21.8,0Z"
                ></path>
              </svg>
            </div>
            <h3 class="h4 fw-bold mb-3">Empresas</h3>
            <p class="text-body-secondary mb-4">
              Estandariza la imagen de todo tu equipo. Controla la información
              que cada colaborador comparte y actualiza datos en tiempo real
              desde un panel centralizado.
            </p>
            <ul class="target-list list-unstyled">
              <li>· Fuerzas de ventas</li>
              <li>· Directivos y ejecutivos</li>
              <li>· Equipos de reclutamiento</li>
              <li>· Distribuidores y representantes</li>
            </ul>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-5" data-aos="fade-up" data-aos-delay="100">
          <div class="target-card h-100 p-5">
            <div class="target-icon mb-4">
              <svg
                width="38"
                height="38"
                fill="#633fb9"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
